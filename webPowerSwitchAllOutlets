// Wi-Fi credentials
const char* ssid     = "Sweetpea";
const char* password = "6c3x%Bve2kU@";

// Power Switch config
const char* powerSwitchUser = "admin";
const char* powerSwitchPass = "1234";

// Editable IP configuration for each power strip
const char* FOH_POWER_IP = "192.168.8.10";
const char* STAGE_LEFT_POWER_IP = "192.168.8.11";
const char* STAGE_RIGHT_POWER_IP = "192.168.8.12";
const char* AMP_RACK_POWER_IP = "192.168.8.13";

// Each entry represents a DLI Web Power Switch Pro unit that already exposes an
// HTTP interface. The base station (this sketch) is the only microcontroller
// involved – it simply talks to the existing web UI that lives on the strip.
struct PowerStrip {
  const char* name;
  const char* ip;
};

PowerStrip powerStrips[] = {
  {"FOH Power", FOH_POWER_IP},
  {"Stg. Left Power", STAGE_LEFT_POWER_IP},
  {"Stg. Right Power", STAGE_RIGHT_POWER_IP},
  {"Amp Rack Power", AMP_RACK_POWER_IP}
};

const uint8_t STRIP_COUNT = sizeof(powerStrips) / sizeof(powerStrips[0]);
const uint8_t OUTLETS_PER_STRIP = 8;

// Pins
#define BUTTON_PIN 12
#define LED_PIN    0
#define STATE_LED_PIN 14  // D5 = GPIO14

HttpServer server(80);

void handleRoot();
void handleControl();
void handleNotFound();
void toggleAllStrips();
bool getOutletStates(const PowerStrip& strip, bool* states, uint8_t count);
bool getStripCurrent(const PowerStrip& strip, float& amps);
bool sendOutletCommand(const PowerStrip& strip, uint8_t outlet, const String& command);
void handleStatus();
void handleCommandRequest(const char* command);
void handleErrorMarker();
void handleOptions();
void sendJsonPayload(int code, const String& payload);
bool applyCommandToAll(const String& command);
bool parseCurrentMeasurement(const String& payload, float& amps);
bool extractCurrentFromJson(JsonVariantConst variant, float& amps);
bool parseNumericString(const String& payload, float& value);

enum class SystemState : uint8_t {
  Off,
  On,
  Mixed,
  Error
};

SystemState readSystemState();
const char* toStateString(SystemState state);
void updateStateIndicator(SystemState state);

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("Starting up...");

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, HIGH); // LED off
  pinMode(STATE_LED_PIN, OUTPUT);
  digitalWrite(STATE_LED_PIN, LOW);  // off by default

#if defined(ESP8266) || defined(ESP32)
  WiFi.mode(WIFI_STA);
#endif
  WiFi.begin(ssid, password);
  Serial.print("Connecting to Wi-Fi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected. IP: " + WiFi.localIP().toString());

  server.on("/", handleRoot);
  server.on("/control", HTTP_POST, handleControl);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/status", HTTP_OPTIONS, handleOptions);
  server.on("/on", HTTP_GET, []() { handleCommandRequest("ON"); });
  server.on("/on", HTTP_OPTIONS, handleOptions);
  server.on("/off", HTTP_GET, []() { handleCommandRequest("OFF"); });
  server.on("/off", HTTP_OPTIONS, handleOptions);
  server.on("/error", HTTP_GET, handleErrorMarker);
  server.on("/error", HTTP_OPTIONS, handleOptions);
  server.onNotFound(handleNotFound);

  server.begin();
  Serial.println("Web server started");
}

void loop() {
  server.handleClient();

  static unsigned long lastStatePoll = 0;
  const unsigned long STATE_POLL_INTERVAL_MS = 5000;
  unsigned long now = millis();
  if (now - lastStatePoll >= STATE_POLL_INTERVAL_MS || lastStatePoll == 0) {
    lastStatePoll = now;
    updateStateIndicator(readSystemState());
  }

  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50);  // debounce
    if (digitalRead(BUTTON_PIN) == LOW) {
      Serial.println("Button pressed → toggling all outlets on all strips");
      digitalWrite(LED_PIN, LOW);
      toggleAllStrips();
      while (digitalRead(BUTTON_PIN) == LOW) delay(10);  // wait for release
      digitalWrite(LED_PIN, HIGH);
      Serial.println("Button released");
    }
  }
}

void toggleAllStrips() {
  SystemState currentState = readSystemState();
  String command = (currentState == SystemState::On) ? "OFF" : "ON";
  Serial.println("Sending command to all outlets on every strip: " + command);

  bool success = applyCommandToAll(command);
  if (!success) {
    Serial.println("One or more outlets failed to process the toggle command");
  }

  updateStateIndicator(readSystemState());
}

bool getOutletStates(const PowerStrip& strip, bool* states, uint8_t count) {
  WiFiClient client;
  HTTPClient http;

  client.setTimeout(5000);
  String url = String("http://") + strip.ip + "/restapi/relay/outlets/";
  http.begin(client, url);
  http.setAuthorization(powerSwitchUser, powerSwitchPass);

  int httpCode = http.GET();
  String payload = http.getString();
  http.end();

  Serial.print("[Status] ");
  Serial.print(strip.name);
  Serial.print(" (HTTP ");
  Serial.print(httpCode);
  Serial.println(")");
  Serial.println(payload);

  if (httpCode != 200) {
    return false;
  }

  StaticJsonDocument<2048> doc;
  DeserializationError err = deserializeJson(doc, payload);
  if (err) {
    Serial.print("JSON parse error: ");
    Serial.println(err.c_str());
    return false;
  }

  uint8_t available = min<uint8_t>(count, doc.size());
  for (uint8_t i = 0; i < available; i++) {
    states[i] = doc[i]["state"].as<bool>();
  }
  for (uint8_t i = available; i < count; i++) {
    states[i] = false;
  }

  return true;
}

bool getStripCurrent(const PowerStrip& strip, float& amps) {
  static const char* const ENDPOINTS[] = {
      "/restapi/relay/amps/",
      "/restapi/relay/current/",
      "/restapi/relay/status/",
      "/restapi/amps",
      "/current",
      "/amps"};

  for (uint8_t i = 0; i < sizeof(ENDPOINTS) / sizeof(ENDPOINTS[0]); i++) {
    WiFiClient client;
    HTTPClient http;

    client.setTimeout(5000);
    String url = String("http://") + strip.ip + ENDPOINTS[i];
    http.begin(client, url);
    http.setAuthorization(powerSwitchUser, powerSwitchPass);

    int httpCode = http.GET();
    String payload = http.getString();
    http.end();

    Serial.print("[Current] ");
    Serial.print(strip.name);
    Serial.print(" @ ");
    Serial.print(ENDPOINTS[i]);
    Serial.print(" (HTTP ");
    Serial.print(httpCode);
    Serial.println(")");

    if (httpCode != 200) {
      continue;
    }

    if (parseCurrentMeasurement(payload, amps)) {
      Serial.print("[Current] Parsed current for ");
      Serial.print(strip.name);
      Serial.print(": ");
      Serial.print(amps, 3);
      Serial.println(" A");
      return true;
    }
  }

  Serial.print("[Current] Unable to determine current draw for ");
  Serial.println(strip.name);
  return false;
}

bool sendOutletCommand(const PowerStrip& strip, uint8_t outlet, const String& command) {
  WiFiClient client;
  HTTPClient http;

  client.setTimeout(5000);
  String url = String("http://") + strip.ip + "/outlet?" + String(outlet) + "=" + command;
  http.begin(client, url);
  http.setAuthorization(powerSwitchUser, powerSwitchPass);

  int httpCode = http.GET();
  http.end();

  Serial.print("[Command] ");
  Serial.print(strip.name);
  Serial.print(" - Outlet ");
  Serial.print(outlet);
  Serial.print(" → ");
  Serial.print(command);
  Serial.print(" (HTTP ");
  Serial.print(httpCode);
  Serial.println(")");

  return httpCode == 200;
}

bool applyCommandToAll(const String& command) {
  String normalized = command;
  normalized.toUpperCase();

  bool success = true;
  for (uint8_t stripIndex = 0; stripIndex < STRIP_COUNT; stripIndex++) {
    for (uint8_t outlet = 1; outlet <= OUTLETS_PER_STRIP; outlet++) {
      if (!sendOutletCommand(powerStrips[stripIndex], outlet, normalized)) {
        success = false;
      }
    }
  }

  return success;
}

SystemState readSystemState() {
  bool anyFailure = false;
  bool anyOn = false;
  bool anyOff = false;
  bool outletStates[OUTLETS_PER_STRIP];

  for (uint8_t stripIndex = 0; stripIndex < STRIP_COUNT; stripIndex++) {
    bool ok = getOutletStates(powerStrips[stripIndex], outletStates, OUTLETS_PER_STRIP);
    if (!ok) {
      anyFailure = true;
      continue;
    }

    for (uint8_t outlet = 0; outlet < OUTLETS_PER_STRIP; outlet++) {
      if (outletStates[outlet]) {
        anyOn = true;
      } else {
        anyOff = true;
      }
    }
  }

  if (anyFailure) {
    return SystemState::Error;
  }
  if (anyOn && anyOff) {
    return SystemState::Mixed;
  }
  if (anyOn) {
    return SystemState::On;
  }
  if (anyOff) {
    return SystemState::Off;
  }

  return SystemState::Error;
}

const char* toStateString(SystemState state) {
  switch (state) {
    case SystemState::On:
      return "on";
    case SystemState::Off:
      return "off";
    case SystemState::Mixed:
    case SystemState::Error:
    default:
      return "error";
  }
}

void updateStateIndicator(SystemState state) {
  switch (state) {
    case SystemState::On:
      digitalWrite(STATE_LED_PIN, HIGH);
      break;
    case SystemState::Off:
      digitalWrite(STATE_LED_PIN, LOW);
      break;
    case SystemState::Mixed:
    case SystemState::Error:
    default:
      digitalWrite(STATE_LED_PIN, LOW);
      break;
  }
}

void sendJsonPayload(int code, const String& payload) {
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
  server.send(code, "application/json", payload);
}

bool parseCurrentMeasurement(const String& payload, float& amps) {
  StaticJsonDocument<512> doc;
  DeserializationError err = deserializeJson(doc, payload);
  if (!err) {
    if (extractCurrentFromJson(doc.as<JsonVariantConst>(), amps)) {
      return true;
    }
  }

  return parseNumericString(payload, amps);
}

bool extractCurrentFromJson(JsonVariantConst variant, float& amps) {
  if (variant.is<JsonObjectConst>()) {
    JsonObjectConst obj = variant.as<JsonObjectConst>();

    if (obj.containsKey("amps")) {
      amps = obj["amps"].as<float>();
      return true;
    }
    if (obj.containsKey("current")) {
      amps = obj["current"].as<float>();
      return true;
    }
    if (obj.containsKey("value")) {
      amps = obj["value"].as<float>();
      return true;
    }

    for (JsonPairConst kvp : obj) {
      JsonVariantConst nested = kvp.value();
      const char* key = kvp.key().c_str();
      if (key != nullptr) {
        String lowered(key);
        lowered.toLowerCase();
        if (lowered.indexOf("amp") != -1 || lowered.indexOf("current") != -1) {
          if (nested.is<float>() || nested.is<int>()) {
            amps = nested.as<float>();
            return true;
          }
          if (nested.is<const char*>()) {
            const char* text = nested.as<const char*>();
            if (text != nullptr) {
              float numeric = 0.0f;
              if (parseNumericString(String(text), numeric)) {
                amps = numeric;
                return true;
              }
            }
          }
        }
      }

      if (nested.is<JsonObjectConst>() || nested.is<JsonArrayConst>()) {
        if (extractCurrentFromJson(nested, amps)) {
          return true;
        }
      }
    }
  } else if (variant.is<JsonArrayConst>()) {
    for (JsonVariantConst nested : variant.as<JsonArrayConst>()) {
      if (extractCurrentFromJson(nested, amps)) {
        return true;
      }
    }
  } else if (variant.is<float>() || variant.is<int>()) {
    amps = variant.as<float>();
    return true;
  }

  return false;
}

bool parseNumericString(const String& payload, float& value) {
  String trimmed = payload;
  trimmed.trim();
  if (trimmed.length() == 0) {
    return false;
  }

  int end = trimmed.length();
  while (end > 0) {
    char c = trimmed[end - 1];
    if (isdigit(static_cast<unsigned char>(c)) || c == '.' || c == '-' || c == '+' || c == 'e' || c == 'E') {
      break;
    }
    end--;
  }

  if (end > 0 && end < trimmed.length()) {
    trimmed.remove(end);
  }

  trimmed.trim();
  if (trimmed.length() == 0) {
    return false;
  }

  bool hasDigit = false;
  for (uint16_t i = 0; i < trimmed.length(); i++) {
    if (isdigit(static_cast<unsigned char>(trimmed[i]))) {
      hasDigit = true;
      break;
    }
  }

  if (!hasDigit) {
    return false;
  }

  value = trimmed.toFloat();
  if (value == 0.0f) {
    if (trimmed == "0" || trimmed == "0.0" || trimmed == "0.00" || trimmed == "0.000" ||
        trimmed.startsWith("0.") || trimmed.startsWith("-0.") || trimmed.startsWith("+0.")) {
      return true;
    }
    return false;
  }

  return true;
}

void handleStatus() {
  SystemState state = readSystemState();

  StaticJsonDocument<768> doc;
  doc["power"] = toStateString(state);
  if (state == SystemState::Mixed) {
    doc["details"] = "Mixed outlet states detected";
  } else if (state == SystemState::Error) {
    doc["details"] = "Unable to retrieve outlet states from one or more strips";
  }
  doc["timestamp"] = millis();

  JsonArray strips = doc.createNestedArray("strips");
  float totalCurrent = 0.0f;
  bool anyCurrent = false;
  for (uint8_t i = 0; i < STRIP_COUNT; i++) {
    JsonObject strip = strips.createNestedObject();
    strip["name"] = powerStrips[i].name;

    float amps = 0.0f;
    bool hasCurrent = getStripCurrent(powerStrips[i], amps);
    strip["current_available"] = hasCurrent;
    if (hasCurrent) {
      strip["current"] = amps;
      totalCurrent += amps;
      anyCurrent = true;
    }
  }

  if (anyCurrent) {
    doc["total_current"] = totalCurrent;
  }

  String payload;
  serializeJson(doc, payload);
  sendJsonPayload(200, payload);
}

void handleCommandRequest(const char* command) {
  String normalized(command);
  normalized.toUpperCase();

  bool success = applyCommandToAll(normalized);
  SystemState state = readSystemState();
  updateStateIndicator(state);

  StaticJsonDocument<256> doc;
  doc["command"] = normalized;
  doc["accepted"] = success;
  doc["power"] = toStateString(state);
  if (!success) {
    doc["details"] = "One or more outlets failed to apply the requested command";
  }

  String payload;
  serializeJson(doc, payload);
  sendJsonPayload(success ? 200 : 502, payload);
}

void handleErrorMarker() {
  StaticJsonDocument<192> doc;
  doc["accepted"] = false;
  doc["message"] = "Manual error state is not supported by this firmware";

  String payload;
  serializeJson(doc, payload);
  sendJsonPayload(501, payload);
}

void handleOptions() {
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
  server.send(204, "text/plain", "");
}

void handleRoot() {
  float stripCurrents[STRIP_COUNT];
  bool stripCurrentAvailable[STRIP_COUNT];
  float totalCurrent = 0.0f;
  bool anyCurrent = false;

  for (uint8_t i = 0; i < STRIP_COUNT; i++) {
    float amps = 0.0f;
    bool hasCurrent = getStripCurrent(powerStrips[i], amps);
    stripCurrents[i] = amps;
    stripCurrentAvailable[i] = hasCurrent;
    if (hasCurrent) {
      totalCurrent += amps;
      anyCurrent = true;
    }
  }

  String html =
      "<!DOCTYPE html><html><head><meta charset='UTF-8'>"
      "<meta name='viewport' content='width=device-width, initial-scale=1.0'>"
      "<title>Power Sequencer</title>"
      "<style>body{font-family:Arial,sans-serif;margin:0;padding:1rem;background:#f2f2f2;}"
      "h1{text-align:center;}section{background:#fff;border-radius:8px;padding:1rem;margin:1rem auto;max-width:600px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}"
      ".outlet{display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid #ddd;}"
      ".outlet:last-child{border-bottom:none;}"
      ".status.on{color:#1b5e20;font-weight:bold;}"
      ".status.off{color:#c62828;font-weight:bold;}"
      ".current{margin:.5rem 0;font-size:.95rem;color:#424242;}"
      ".current .value{font-weight:bold;color:#1976d2;}"
      ".current.unavailable .value{color:#c62828;}"
      ".summary{background:#fff;border-radius:8px;padding:1rem;margin:1rem auto;max-width:600px;box-shadow:0 2px 8px rgba(0,0,0,0.1);}"
      ".summary.unavailable .value{color:#c62828;}"
      ".summary .help{margin-top:.5rem;color:#757575;font-size:.9rem;}"
      "button{padding:.4rem .8rem;border:none;border-radius:4px;background:#1976d2;color:#fff;font-size:1rem;cursor:pointer;}"
      "button.off{background:#c62828;}form{margin:0;}"
      "</style></head><body><h1>Power Sequencer</h1>";

  html += "<section class='summary";
  if (!anyCurrent) {
    html += " unavailable";
  }
  html += "'><h2>Aggregate Load</h2><p class='current";
  if (!anyCurrent) {
    html += " unavailable";
  }
  html += "'>Total current draw: <span class='value'>";
  if (anyCurrent) {
    html += String(totalCurrent, 2) + " A";
  } else {
    html += "N/A";
  }
  html += "</span></p>";
  if (!anyCurrent) {
    html += "<p class='help'>No current readings are available from the connected power strips.</p>";
  }
  html += "</section>";

  bool states[OUTLETS_PER_STRIP];

  for (uint8_t stripIndex = 0; stripIndex < STRIP_COUNT; stripIndex++) {
    html += "<section><h2>" + String(powerStrips[stripIndex].name) + "</h2>";

    bool hasCurrent = stripCurrentAvailable[stripIndex];
    float amps = stripCurrents[stripIndex];
    html += "<p class='current";
    if (!hasCurrent) {
      html += " unavailable";
    }
    html += "'>Current draw: <span class='value'>";
    if (hasCurrent) {
      html += String(amps, 2) + " A";
    } else {
      html += "N/A";
    }
    html += "</span></p>";

    bool ok = getOutletStates(powerStrips[stripIndex], states, OUTLETS_PER_STRIP);
    if (!ok) {
      html += "<p><strong>Unable to retrieve outlet status.</strong></p></section>";
      continue;
    }

    for (uint8_t outlet = 0; outlet < OUTLETS_PER_STRIP; outlet++) {
      bool isOn = states[outlet];
      String statusClass = isOn ? "status on" : "status off";
      String statusText = isOn ? "ON" : "OFF";
      String buttonClass = isOn ? "off" : "";
      String buttonText = isOn ? "Turn Off" : "Turn On";
      String desiredCommand = isOn ? "OFF" : "ON";

      html += "<div class='outlet'><span class='" + statusClass + "'>Outlet " +
              String(outlet + 1) + ": " + statusText + "</span>";
      html += "<form method='POST' action='/control'>";
      html += "<input type='hidden' name='strip' value='" + String(stripIndex) + "'>";
      html += "<input type='hidden' name='outlet' value='" + String(outlet + 1) + "'>";
      html += "<input type='hidden' name='command' value='" + desiredCommand + "'>";
      html += "<button type='submit' class='" + buttonClass + "'>" + buttonText + "</button></form></div>";
    }

    html += "</section>";
  }

  html += "</body></html>";

  server.send(200, "text/html", html);
}
void handleControl() {
  if (!server.hasArg("strip") || !server.hasArg("outlet") || !server.hasArg("command")) {
    server.send(400, "text/plain", "Missing parameters");
    return;
  }

  uint8_t stripIndex = server.arg("strip").toInt();
  uint8_t outlet = server.arg("outlet").toInt();
  String command = server.arg("command");
  command.toUpperCase();

  if (stripIndex >= STRIP_COUNT || outlet == 0 || outlet > OUTLETS_PER_STRIP ||
      (command != "ON" && command != "OFF")) {
    server.send(400, "text/plain", "Invalid parameters");
    return;
  }

  bool success = sendOutletCommand(powerStrips[stripIndex], outlet, command);
  if (!success) {
    server.send(502, "text/plain", "Failed to control outlet");
    return;
  }

  server.sendHeader("Location", "/");
  server.send(303, "text/plain", "Redirecting");
}

void handleNotFound() {
  server.send(404, "text/plain", "Not found");
}
