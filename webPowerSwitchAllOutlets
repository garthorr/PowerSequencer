#include <ESP8266WiFi.h>
#include <ESP8266HTTPClient.h>
#include <ArduinoJson.h>

// Wi-Fi credentials
const char* ssid     = "Sweetpea";
const char* password = "6c3x%Bve2kU@";

// Power Switch config
const char* powerSwitchIP   = "192.168.50.90";
const char* powerSwitchUser = "admin";
const char* powerSwitchPass = "1234";

// Pins
#define BUTTON_PIN 12
#define LED_PIN    0
#define STATE_LED_PIN 14  // D5 = GPIO14

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("Starting up...");

  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, HIGH); // LED off
  pinMode(STATE_LED_PIN, OUTPUT);
  digitalWrite(STATE_LED_PIN, LOW);  // off by default

  WiFi.begin(ssid, password);
  Serial.print("Connecting to Wi-Fi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected. IP: " + WiFi.localIP().toString());
}

void loop() {
  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50);  // debounce
    if (digitalRead(BUTTON_PIN) == LOW) {
      Serial.println("Button pressed → toggling all outlets");
      digitalWrite(LED_PIN, LOW);
      toggleAllOutlets();
      while (digitalRead(BUTTON_PIN) == LOW) delay(10);  // wait for release
      digitalWrite(LED_PIN, HIGH);
      Serial.println("Button released");
    }
  }
}

void toggleAllOutlets() {
  bool allOn = true;
  bool outletStates[8];

  if (!getAllOutletStates(outletStates, 8)) {
    Serial.println("Failed to get outlet states.");
    return;
  }

  for (int i = 0; i < 8; i++) {
    if (!outletStates[i]) {
      allOn = false;
      break;
    }
  }

  String command = allOn ? "OFF" : "ON";
  Serial.println("Sending command to all outlets: " + command);
  digitalWrite(STATE_LED_PIN, (command == "ON") ? HIGH : LOW);
  for (int i = 1; i <= 8; i++) {
    sendOutletCommand(i, command);
  }
}

bool getAllOutletStates(bool* states, int count) {
  WiFiClient client;
  HTTPClient http;

  String url = String("http://") + powerSwitchIP + "/restapi/relay/outlets/";
  http.begin(client, url);
  http.setAuthorization(powerSwitchUser, powerSwitchPass);

  int httpCode = http.GET();
  String payload = http.getString();
  http.end();

  Serial.println("HTTP " + String(httpCode));
  Serial.println("Raw outlet state response: " + payload);

  if (httpCode != 200) return false;

  StaticJsonDocument<2048> doc;
  DeserializationError err = deserializeJson(doc, payload);
  if (err) return false;

  for (int i = 0; i < count; i++) {
    states[i] = doc[i]["state"];
    Serial.print("Outlet ");
    Serial.print(i + 1);
    Serial.print(": ");
    Serial.println(states[i] ? "ON" : "OFF");
  }

  return true;
}

void sendOutletCommand(int outlet, String command) {
  WiFiClient client;
  HTTPClient http;

  String url = String("http://") + powerSwitchIP + "/outlet?" + String(outlet) + "=" + command;
  http.begin(client, url);
  http.setAuthorization(powerSwitchUser, powerSwitchPass);

  int httpCode = http.GET();
  http.end();

  Serial.println("Outlet " + String(outlet) + " → " + command + " (HTTP " + httpCode + ")");
}
