const size_t INDEX_HTML_SIZE = 6239;

const uint8_t STRIP_COUNT = sizeof(powerStrips) / sizeof(powerStrips[0]);
HttpServer server(80);

enum class SystemState : uint8_t {
  Off,
  On,
  Mixed,
  Error,
  Sequencing
};

SystemState globalState = SystemState::Off;

void handleRoot();
void handleStatus();
void handleOptions();
void updateStateIndicator();
bool applyCommandSequentially(const String& command);
void pollStrip(uint8_t index);
SystemState calculateGlobalState();

void setup() {
  Serial.begin(115200);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(STATUS_LED_PIN, OUTPUT);

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected. IP: " + WiFi.localIP().toString());

  server.on("/", HTTP_GET, handleRoot);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/on", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    bool success = applyCommandSequentially("ON");
    server.send(success ? 200 : 502, "application/json", "{\"success\":" + String(success ? "true" : "false") + "}");
  });
  server.on("/off", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    bool success = applyCommandSequentially("OFF");
    server.send(success ? 200 : 502, "application/json", "{\"success\":" + String(success ? "true" : "false") + "}");
  });
  server.onNotFound(handleOptions);

  server.begin();
}

void loop() {
  server.handleClient();

  static unsigned long lastPoll = 0;
  static uint8_t currentStrip = 0;

  if (millis() - lastPoll >= POLL_INTERVAL_MS) {
    lastPoll = millis();
    if (globalState != SystemState::Sequencing) {
      pollStrip(currentStrip);
      currentStrip = (currentStrip + 1) % STRIP_COUNT;
      globalState = calculateGlobalState();
    }
  }

  updateStateIndicator();

  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50);
    if (digitalRead(BUTTON_PIN) == LOW) {
      String cmd = (globalState == SystemState::On) ? "OFF" : "ON";
      applyCommandSequentially(cmd);
      while (digitalRead(BUTTON_PIN) == LOW) delay(10);
    }
  }
}

void updateStateIndicator() {
  static unsigned long lastToggle = 0;
  static bool ledState = false;

  switch (globalState) {
    case SystemState::On: digitalWrite(STATUS_LED_PIN, HIGH); break;
    case SystemState::Off: digitalWrite(STATUS_LED_PIN, LOW); break;
    case SystemState::Sequencing:
      if (millis() - lastToggle >= 250) { lastToggle = millis(); ledState = !ledState; digitalWrite(STATUS_LED_PIN, ledState); }
      break;
    case SystemState::Error:
    case SystemState::Mixed:
      if (millis() - lastToggle >= 100) { lastToggle = millis(); ledState = !ledState; digitalWrite(STATUS_LED_PIN, ledState); }
      break;
    default: digitalWrite(STATUS_LED_PIN, LOW);
  }
}

bool sendBatchCommand(const PowerStrip& strip, const String& command) {
  WiFiClient client;
  HTTPClient http;
  client.setTimeout(5000);
  String url = "http://" + String(strip.ip) + "/outlet?a=" + command;
  http.begin(client, url);
  http.setAuthorization(powerSwitchUser, powerSwitchPass);
  int code = http.GET();
  http.end();
  return code == 200;
}

bool applyCommandSequentially(const String& command) {
  globalState = SystemState::Sequencing;
  bool allSuccess = true;
  for (uint8_t i = 0; i < STRIP_COUNT; i++) {
    if (!sendBatchCommand(powerStrips[i], command)) {
      allSuccess = false;
    }
    if (i < STRIP_COUNT - 1) {
      unsigned long start = millis();
      while(millis() - start < SEQUENCE_DELAY_MS) {
        server.handleClient();
        updateStateIndicator();
        delay(10);
      }
    }
  }
  // Force a full poll after sequencing
  for (uint8_t i = 0; i < STRIP_COUNT; i++) pollStrip(i);
  globalState = calculateGlobalState();
  return allSuccess;
}

void pollStrip(uint8_t index) {
  PowerStrip& strip = powerStrips[index];
  WiFiClient client;
  HTTPClient http;
  client.setTimeout(2000);

  // 1. Fetch States
  http.begin(client, "http://" + String(strip.ip) + "/restapi/relay/outlets/");
  http.setAuthorization(powerSwitchUser, powerSwitchPass);
  int code = http.GET();
  if (code == 200) {
    StaticJsonDocument<1024> doc;
    DeserializationError err = deserializeJson(doc, http.getString());
    if (!err && doc.is<JsonArray>()) {
      bool anyOn = false;
      bool anyOff = false;
      for (JsonVariant v : doc.as<JsonArray>()) {
        if (v["state"].as<bool>()) anyOn = true;
        else anyOff = true;
      }
      if (anyOn && anyOff) strip.state = StripState::Mixed;
      else if (anyOn) strip.state = StripState::On;
      else strip.state = StripState::Off;
    } else {
      strip.state = StripState::Error;
    }
  } else {
    strip.state = StripState::Error;
  }
  http.end();

  // 2. Fetch Amps (reusing client/http)
  const char* endpoints[] = {"/restapi/relay/amps/", "/restapi/relay/current/", "/amps"};
  bool found = false;
  if (strip.workingEndpoint.length() > 0) {
    http.begin(client, "http://" + String(strip.ip) + strip.workingEndpoint);
    http.setAuthorization(powerSwitchUser, powerSwitchPass);
    if (http.GET() == 200) {
      strip.amps = http.getString().toFloat();
      strip.currentAvailable = true;
      found = true;
    }
    http.end();
  }

  if (!found) {
    for (const char* ep : endpoints) {
      http.begin(client, "http://" + String(strip.ip) + ep);
      http.setAuthorization(powerSwitchUser, powerSwitchPass);
      if (http.GET() == 200) {
        String p = http.getString();
        strip.amps = p.toFloat();
        strip.currentAvailable = true;
        strip.workingEndpoint = ep;
        found = true;
        http.end();
        break;
      }
      http.end();
    }
    if (!found) strip.currentAvailable = false;
  }
}

SystemState calculateGlobalState() {
  bool anyOn = false;
  bool anyOff = false;
  bool anyError = false;
  bool anyMixed = false;

  for (uint8_t i = 0; i < STRIP_COUNT; i++) {
    if (powerStrips[i].state == StripState::Error || powerStrips[i].state == StripState::Unknown) anyError = true;
    else if (powerStrips[i].state == StripState::Mixed) anyMixed = true;
    else if (powerStrips[i].state == StripState::On) anyOn = true;
    else if (powerStrips[i].state == StripState::Off) anyOff = true;
  }

  if (anyError) return SystemState::Error;
  if (anyMixed || (anyOn && anyOff)) return SystemState::Mixed;
  if (anyOn) return SystemState::On;
  return SystemState::Off;
}

const char* stripStateToStr(StripState s) {
  switch(s) {
    case StripState::On: return "on";
    case StripState::Off: return "off";
    case StripState::Mixed: return "mixed";
    case StripState::Error: return "error";
    default: return "unknown";
  }
}

void handleStatus() {
  DynamicJsonDocument doc(4096);
  SystemState current = globalState;
  const char* powerStrs[] = {"off", "on", "mixed", "error", "sequencing"};
  doc["power"] = powerStrs[(uint8_t)current];

  JsonArray strips = doc.createNestedArray("strips");
  float totalCurrent = 0;
  for (uint8_t i = 0; i < STRIP_COUNT; i++) {
    JsonObject s = strips.createNestedObject();
    s["name"] = powerStrips[i].name;
    s["state"] = stripStateToStr(powerStrips[i].state);
    if (powerStrips[i].currentAvailable) {
      s["current"] = powerStrips[i].amps;
      s["current_available"] = true;
      totalCurrent += powerStrips[i].amps;
    } else {
      s["current_available"] = false;
    }
  }
  doc["total_current"] = totalCurrent;

  String response;
  serializeJson(doc, response);
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.send(200, "application/json", response);
}

void handleRoot() {
  server.sendHeader("Content-Encoding", "identity");
  server.send_P(200, "text/html", (const char*)INDEX_HTML, INDEX_HTML_SIZE);
}

void handleOptions() {
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
  server.send(204);
}
